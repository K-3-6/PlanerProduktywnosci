<Window x:Class="PlanerDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PlanerDesktop"
        mc:Ignorable="d"
        Title="Planer Produktywności - Desktop" Height="500" Width="850" Background="#f4f6f9">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Lewy Panel: Formularz dodawania -->
        <StackPanel Grid.Column="0" Margin="0,0,15,0">
            <TextBlock Text="DODAJ NOWE ZADANIE" FontWeight="Bold" FontSize="14" Margin="0,0,0,15" Foreground="#2c3e50"/>

            <TextBlock Text="Tytuł:" Margin="0,5,0,2"/>
            <TextBox x:Name="TxtTitle" Padding="5"/>

            <TextBlock Text="Opis:" Margin="0,10,0,2"/>
            <TextBox x:Name="TxtDescription" Height="60" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Padding="5"/>

            <TextBlock Text="Kategoria:" Margin="0,10,0,2"/>
            <ComboBox x:Name="CmbCategory" Padding="5">
                <ComboBoxItem Content="Praca" IsSelected="True"/>
                <ComboBoxItem Content="Dom"/>
                <ComboBoxItem Content="Nauka"/>
            </ComboBox>

            <TextBlock Text="Priorytet:" Margin="0,10,0,2"/>
            <ComboBox x:Name="CmbPriority" Padding="5">
                <ComboBoxItem Content="Niski"/>
                <ComboBoxItem Content="Średni" IsSelected="True"/>
                <ComboBoxItem Content="Wysoki"/>
            </ComboBox>

            <Button x:Name="BtnAddTask" Content="Zapisz zadanie" Margin="0,20,0,0" Padding="10" 
                    Background="#2ecc71" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="BtnAddTask_Click"/>
        </StackPanel>

        <!-- Prawy Panel: Lista Zadań (DataGrid) -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="TWOJA LISTA ZADAŃ (Z BAZY SQLITE)" FontWeight="Bold" FontSize="14" Margin="0,0,0,15" Foreground="#2c3e50"/>

            <DataGrid x:Name="DgTasks" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Background="White" RowHeaderWidth="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tytuł" Binding="{Binding Title}" Width="150"/>
                    <DataGridTextColumn Header="Kategoria" Binding="{Binding Category}" Width="100"/>
                    <DataGridTextColumn Header="Priorytet" Binding="{Binding Priority}" Width="100"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                    <DataGridTextColumn Header="Opis" Binding="{Binding Description}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button x:Name="BtnRefresh" Content="Odśwież dane" Padding="10,5" Margin="0,0,10,0" Background="#34495e" Foreground="White" BorderThickness="0" Click="BtnRefresh_Click"/>
                <Button x:Name="BtnDeleteTask" Content="Usuń zaznaczone" Padding="10,5" Background="#e74c3c" Foreground="White" BorderThickness="0" Click="BtnDeleteTask_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
